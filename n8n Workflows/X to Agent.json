    },
    "Transform Mentions": {
      "main": [[{ "node": "Merge Mentions + DMs", "type": "main", "index": 0 }]]
    },
    "Transform DMs": {
      "main": [[{ "node": "Merge Mentions + DMs", "type": "main", "index": 1 }]]
    },
    "Merge Mentions + DMs": {
      "main": [[{ "node": "Has Events?", "type": "main", "index": 0 }]]
    },
    "Has Events?": {
      "main": [
        [{ "node": "Write Event File", "type": "main", "index": 0 }],
        []
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "staticData": null,
  "tags": [{ "name": "" }]
}
